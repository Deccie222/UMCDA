@startuml mcdaHub_Paper_Class_Diagram

skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam shadowing false
skinparam roundcorner 5

abstract class TaskResult {
  + task_type : character
  + raw_result : numeric
  + metadata : list
  --
  + initialize(task_type, raw_result, metadata)
}

class ResultRanking {
  + ranking_table : data.frame
  --
  - n_alternatives : integer
  --
  + initialize(raw_result, metadata)
  + print()
}

class ResultSorting {
  + categories : character[]
  + sorting_table : data.frame
  --
  + initialize(raw_result, metadata)
  + print()
  - assign_categories(raw_result, metadata)
}

class ResultChoice {
  + choice : character[]
  + choice_table : data.frame
  --
  + initialize(raw_result, metadata)
  + print()
}

abstract class TaskDecision {
  + type : character
  + task_data : list
  --
  + initialize(..., type)
  + validate(normalize_weights)
  + n_alt() : integer
  + n_crit() : integer
  + get_perf(alt_name, crit_name) : matrix
  + set_perf(perf, normalize_weights)
  + alt_names() : character[]
  + crit_names() : character[]
  + set_w(weights, normalize_weights)
  + set_d(directions)
  + get_w(crit_name) : numeric
  + get_d(crit_name) : character
}

class TaskRanking {
  + initialize(alt, crit, perf, weight, direction, normalize_weights)
  + print()
}

class TaskSorting {
  + n_cats : integer
  + cat_names : character[]
  + cats : list
  + prof : matrix
  + prof_order : character[]
  + assign_rule : character
  + internal_profiles : character[]
  --
  + initialize(alt, crit, perf, weight, direction, n_cats, cat_names, cats, prof, prof_order, assign_rule, normalize_weights)
  + print()
}

class TaskChoice {
  + initialize(alt, crit, perf, weight, direction, normalize_weights)
}

abstract class Decider {
  + state : list
  --
  + initialize()
  + solve(task) : TaskResult
  --
  - {abstract} compute(task) : numeric
}

class DeciderTOPSIS {
  + initialize()
  --
  - compute(task) : numeric
  - check_ranking_choice_fields(task)
  - check_sorting_fields(task)
  - validate_topsis_inputs(A, w, alt, crit)
  - convert_directions_for_rmcda(A, d, alt, crit)
  - compute_ranking_choice(task) : numeric
  - compute_sorting(task) : numeric
}

class DeciderPROMETHEE {
  + initialize()
  --
  - compute(task) : numeric
  - check_ranking_choice_fields(task)
  - check_sorting_fields(task)
  - check_duplicated_alternatives(A, alt)
  - check_constant_criteria(A, crit)
  - convert_directions_for_rmcda(A, d, crit)
  - compute_ranking_choice(task) : numeric
  - compute_sorting(task) : numeric
}

class DeciderAHP {
  + initialize()
  --
  - compute(task) : numeric
  - check_ranking_choice_fields(task)
  - check_sorting_fields(task)
  - validate_ahp_inputs(pair_crit, pair_alt, crit, alt)
  - compute_ranking_choice(task) : numeric
  - compute_sorting(task) : numeric
  - find_weight(A) : list
}

class WeightPerturbation {
  + task : TaskRanking
  + decider : Decider
  + perturb_rg : numeric
  + perturb_n : integer
  + orig_rslt : ResultRanking
  + perturb_w : matrix
  + perturb_rslt : list
  --
  + initialize(task, decider, perturb_rg, perturb_n)
  + weight_perturb()
  + perturb_rank() : matrix
  + perturb_stab_plot(type) : ggplot
  + perturb_rank_corr(method) : matrix
  + perturb_corr_heatmap(method) : pheatmap
  --
  - generate_oat_weights() : matrix
  - copy_task(new_weights) : TaskRanking
}

class AlgoRankCorrelation {
  + task : TaskRanking
  + decider : list
  + correlation_matrix : matrix
  --
  + initialize(task, decider)
  + calculate() : matrix
  + print()
}

TaskResult <|-- ResultRanking
TaskResult <|-- ResultSorting
TaskResult <|-- ResultChoice

TaskDecision <|-- TaskRanking
TaskDecision <|-- TaskSorting
TaskDecision <|-- TaskChoice

Decider <|-- DeciderTOPSIS
Decider <|-- DeciderPROMETHEE
Decider <|-- DeciderAHP

Decider ..> TaskDecision : uses
Decider ..> TaskResult : creates
TaskResult ..> TaskDecision : contains

WeightPerturbation ..> TaskRanking : uses
WeightPerturbation ..> Decider : uses
WeightPerturbation ..> ResultRanking : uses

AlgoRankCorrelation ..> TaskRanking : uses
AlgoRankCorrelation ..> Decider : uses
AlgoRankCorrelation ..> ResultRanking : uses

@enduml
