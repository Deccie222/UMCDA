@startuml mcdaHub_Minimal_Class_Diagram

skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam shadowing false
skinparam roundcorner 3
skinparam packageStyle rectangle
skinparam defaultFontSize 11
skinparam classFontSize 11

package "Core Classes" #LightBlue {
  abstract class TaskDecision {
    + type
    + task_data
    --
    + initialize()
    + validate()
    + solve()
  }
  
  abstract class Decider {
    + state
    --
    + initialize()
    + solve(task) : TaskResult
  }
  
  abstract class TaskResult {
    + task_type
    + raw_result
    + metadata
    --
    + initialize()
  }
}

package "Task Types" #LightGreen {
  class TaskRanking
  class TaskSorting
  class TaskChoice
}

package "Result Types" #LightYellow {
  class ResultRanking {
    + ranking_table
  }
  class ResultSorting {
    + categories
    + sorting_table
  }
  class ResultChoice {
    + choice
    + choice_table
  }
}

package "Algorithms" #LightCoral {
  class DeciderTOPSIS
  class DeciderPROMETHEE
  class DeciderAHP
}

package "Analysis Tools" #LightGray {
  class WeightPerturbation {
    + task
    + decider
    --
    + weight_perturb()
    + perturb_rank()
    + perturb_stab_plot()
  }
  
  class AlgoRankCorrelation {
    + task
    + decider
    --
    + calculate()
  }
}

TaskDecision <|-- TaskRanking
TaskDecision <|-- TaskSorting
TaskDecision <|-- TaskChoice

Decider <|-- DeciderTOPSIS
Decider <|-- DeciderPROMETHEE
Decider <|-- DeciderAHP

TaskResult <|-- ResultRanking
TaskResult <|-- ResultSorting
TaskResult <|-- ResultChoice

Decider ..> TaskDecision
Decider ..> TaskResult

WeightPerturbation ..> TaskRanking
WeightPerturbation ..> Decider
WeightPerturbation ..> ResultRanking

AlgoRankCorrelation ..> TaskRanking
AlgoRankCorrelation ..> Decider
AlgoRankCorrelation ..> ResultRanking

@enduml

