@startuml Decider_Class_Diagram

' ===============================
' Global style for academic paper
' ===============================
hide circle
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam classMethodIconSize 0
skinparam monochrome true
skinparam class {
  BackgroundColor White
  BorderColor Black
  ArrowColor Black
  FontSize 11
}

!define PUBLIC +
!define PRIVATE -
!define PROTECTED #

' ============================================
' Decider Abstract Class (Paper Version)
' ============================================

abstract class Decider {
  PUBLIC state : list
  --
  PUBLIC initialize() : Decider
  PUBLIC solve(task : TaskDecision) : TaskResult
  --
  PRIVATE {abstract} compute(task : TaskDecision) : numeric
}

' ============================================
' Decider Subclasses
' ============================================

class DeciderTOPSIS {
  --
  PUBLIC initialize() : DeciderTOPSIS
  --
  PRIVATE compute(task) : numeric
  --
  PRIVATE check_ranking_choice_fields(task)
  PRIVATE check_sorting_fields(task)
  PRIVATE normalize_matrix(M) : matrix
  PRIVATE compute_ideal_points(norm.M, d) : list
  PRIVATE compute_ranking_choice(task) : numeric
  PRIVATE compute_sorting(task) : numeric
}

class DeciderPROMETHEE {
  --
  PUBLIC initialize() : DeciderPROMETHEE
  --
  PRIVATE compute(task) : numeric
  --
  PRIVATE check_ranking_choice_fields(task)
  PRIVATE check_sorting_fields(task)
  PRIVATE preprocess_matrix(M, d, row_ids, crit_names) : matrix
  PRIVATE compute_ranking_choice(task) : numeric
  PRIVATE compute_sorting(task) : numeric
}

class DeciderAHP {
  --
  PUBLIC initialize() : DeciderAHP
  --
  PRIVATE compute(task) : numeric
  --
  PRIVATE check_ranking_choice_fields(task)
  PRIVATE check_sorting_fields(task)
  PRIVATE compute_ranking_choice(task) : numeric
  PRIVATE compute_sorting(task) : numeric
  PRIVATE find_weight(A) : list
}

' ============================================
' Inheritance Relationships
' ============================================

Decider <|-- DeciderTOPSIS
Decider <|-- DeciderPROMETHEE
Decider <|-- DeciderAHP

@enduml
