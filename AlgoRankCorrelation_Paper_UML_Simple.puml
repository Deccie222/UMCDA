@startuml AlgoRankCorrelation_Class_Diagram_Paper_Simple

' ===============================
' Global style for academic paper
' ===============================
hide circle
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam classMethodIconSize 0
skinparam monochrome true
skinparam class {
  BackgroundColor White
  BorderColor Black
  ArrowColor Black
  FontSize 11
}

!define PUBLIC +
!define PRIVATE -
!define PROTECTED #

' ============================================
' AlgoRankCorrelation Class
' ============================================

class AlgoRankCorrelation {
  PUBLIC task : TaskRanking
  PUBLIC decider : list<Decider>
  PUBLIC correlation_matrix : matrix
  --
  PUBLIC initialize(task : TaskRanking, decider : list<Decider>) : AlgoRankCorrelation
  PUBLIC calculate() : matrix
  PUBLIC print(...)
}

' ============================================
' Dependencies
' ============================================

AlgoRankCorrelation ..> TaskRanking : uses
AlgoRankCorrelation ..> Decider : "solves task\nwith each decider"
AlgoRankCorrelation ..> ResultRanking : "extracts rankings\nfrom results"

@enduml

