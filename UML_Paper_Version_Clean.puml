@startuml mcdaHub_Clean_Class_Diagram

!define TASK_COLOR #E1F5FF
!define RESULT_COLOR #FFF4E1
!define DECIDER_COLOR #FFE1E1
!define TOOL_COLOR #E1FFE1

skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam shadowing false
skinparam roundcorner 5
skinparam packageStyle rectangle
skinparam defaultFontSize 11
skinparam classFontSize 11
skinparam arrowColor #333333
skinparam classBorderColor #333333

package "Task Layer" TASK_COLOR {
  abstract class TaskDecision {
    + type
    + task_data
    --
    + initialize()
    + validate()
    + n_alt()
    + n_crit()
    + get_perf()
    + alt_names()
    + crit_names()
  }
  
  class TaskRanking
  class TaskSorting {
    + cat_names
    + prof
  }
  class TaskChoice
}

package "Result Layer" RESULT_COLOR {
  abstract class TaskResult {
    + task_type
    + raw_result
    + metadata
    --
    + initialize()
  }
  
  class ResultRanking {
    + ranking_table
  }
  class ResultSorting {
    + categories
    + sorting_table
  }
  class ResultChoice {
    + choice
    + choice_table
  }
}

package "Algorithm Layer" DECIDER_COLOR {
  abstract class Decider {
    + state
    --
    + initialize()
    + solve(task) : TaskResult
  }
  
  class DeciderTOPSIS
  class DeciderPROMETHEE
  class DeciderAHP
}

package "Analysis Layer" TOOL_COLOR {
  class WeightPerturbation {
    + task : TaskRanking
    + decider : Decider
    --
    + weight_perturb()
    + perturb_rank()
    + perturb_stab_plot()
  }
  
  class AlgoRankCorrelation {
    + task : TaskRanking
    + decider : list
    --
    + calculate()
  }
}

TaskDecision <|-- TaskRanking
TaskDecision <|-- TaskSorting
TaskDecision <|-- TaskChoice

Decider <|-- DeciderTOPSIS
Decider <|-- DeciderPROMETHEE
Decider <|-- DeciderAHP

TaskResult <|-- ResultRanking
TaskResult <|-- ResultSorting
TaskResult <|-- ResultChoice

Decider ..> TaskDecision
Decider ..> TaskResult

WeightPerturbation ..> TaskRanking
WeightPerturbation ..> Decider
WeightPerturbation ..> ResultRanking

AlgoRankCorrelation ..> TaskRanking
AlgoRankCorrelation ..> Decider
AlgoRankCorrelation ..> ResultRanking

@enduml

