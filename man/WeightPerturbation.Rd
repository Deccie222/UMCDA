# Perform sensitivity analysis
wp <- WeightPerturbation$new(
  task = task,
  decider = decider,
  perturb_rg = 0.3,
  perturb_n = 51
)

# Run analysis
wp$weight_perturb()

# Extract results
rank_mat <- wp$perturb_rank()
wp$perturb_stab_plot(type = "trajectory")
wp$perturb_stab_plot(type = "sd")
}

