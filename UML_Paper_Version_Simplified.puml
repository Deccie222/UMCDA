@startuml mcdaHub_Simplified_Class_Diagram

' Global style for academic paper
' ===============================
hide circle
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam classMethodIconSize 0
skinparam monochrome true
skinparam class {
  BackgroundColor White
  BorderColor Black
  ArrowColor Black
  FontSize 11
}

skinparam linetype ortho
skinparam roundcorner 5
skinparam packageStyle rectangle

' Style for abstract classes (academic paper style)
skinparam abstractClass {
  BackgroundColor White
  BorderColor Black
  BorderStyle bold
  FontStyle italic
}

package "Task Classes" {
  abstract class TaskDecision <<abstract>> {
    + type : character
    + task_data : list
    --
    + initialize(...)
    + validate()
    + n_alt() : integer
    + n_crit() : integer
    + get_perf() : matrix
    + alt_names() : character[]
    + crit_names() : character[]
  }
  
  class TaskRanking {
    + initialize(...)
    + print()
  }
  
  class TaskSorting {
    + cat_names : character[]
    + prof : matrix
    --
    + initialize(...)
    + print()
  }
  
  class TaskChoice {
    + initialize(...)
  }
}

package "Result Classes" {
  abstract class TaskResult <<abstract>> {
    + task_type : character
    + raw_result : numeric
    + metadata : list
    --
    + initialize(...)
  }
  
  class ResultRanking {
    + ranking_table : data.frame
    --
    + initialize(...)
    + print()
  }
  
  class ResultSorting {
    + categories : character[]
    + sorting_table : data.frame
    --
    + initialize(...)
    + print()
  }
  
  class ResultChoice {
    + choice : character[]
    + choice_table : data.frame
    --
    + initialize(...)
    + print()
  }
}

package "Algorithm Classes" {
  abstract class Decider <<abstract>> {
    + state : list
    --
    + initialize()
    + solve(task) : TaskResult
    --
    - {abstract} compute(task) : numeric
  }
  
  class DeciderTOPSIS {
    + initialize()
    --
    - compute(task) : numeric
  }
  
  class DeciderPROMETHEE {
    + initialize()
    --
    - compute(task) : numeric
  }
  
  class DeciderAHP {
    + initialize()
    --
    - compute(task) : numeric
  }
}

package "Analysis Tools" {
  class WeightPerturbation {
    + task : TaskRanking
    + decider : Decider
    + perturb_rg : numeric
    + perturb_n : integer
    --
    + initialize(...)
    + weight_perturb()
    + perturb_rank() : matrix
    + perturb_stab_plot(type)
    + perturb_corr_heatmap(method)
  }
  
  class AlgoRankCorrelation {
    + task : TaskRanking
    + decider : list
    + correlation_matrix : matrix
    --
    + initialize(...)
    + calculate() : matrix
    + print()
  }
}

TaskResult <|-- ResultRanking
TaskResult <|-- ResultSorting
TaskResult <|-- ResultChoice

TaskDecision <|-- TaskRanking
TaskDecision <|-- TaskSorting
TaskDecision <|-- TaskChoice

Decider <|-- DeciderTOPSIS
Decider <|-- DeciderPROMETHEE
Decider <|-- DeciderAHP

Decider ..> TaskDecision
Decider ..> TaskResult

WeightPerturbation ..> TaskRanking
WeightPerturbation ..> Decider
WeightPerturbation ..> ResultRanking

AlgoRankCorrelation ..> TaskRanking
AlgoRankCorrelation ..> Decider
AlgoRankCorrelation ..> ResultRanking

@enduml
